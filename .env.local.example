# Giftr environment variables.
# Copy this file to .env.local and fill in the values you need.
#
# Demo / mock behaviour:
# - Set BITREFILL_MOCK=true to bypass all real Bitrefill API calls (no real
#   purchases are made; deterministic mock gift codes are returned instead).
# - When RESEND_API_KEY is unset, the app runs in demo mode and email content
#   is logged to the server console instead of being delivered.
# - When OPENAI_API_KEY is unset, AI gift selection falls back to a deterministic
#   demo selection (no network call) so the flows still complete. Set a real key
#   to have GPT-4o choose the gift.
#
# For a fully offline, no-cost demo: set BITREFILL_MOCK=true and leave
# OPENAI_API_KEY and RESEND_API_KEY blank. Only the Supabase variables are
# strictly required (the app stores raffles, entries and gifts there).

# Public Supabase project URL (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only, never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API key used for AI gift selection (GPT-4o). Leave blank to use the
# deterministic demo fallback instead of calling the model.
OPENAI_API_KEY=

# Resend API key used to send gift emails. Leave blank to log emails to console.
RESEND_API_KEY=

# Optional local-only escape hatch: when true in non-production, logs full mock
# gift codes if Resend is disabled. Defaults to redacted logs.
LOG_DEMO_GIFT_CODES=false

# From address used for outgoing Giftr emails. Must be a verified Resend sender.
RESEND_FROM_EMAIL=giftr@yourdomain.com

# Bitrefill API key for purchasing gift cards.
BITREFILL_API_KEY=

# Bitrefill API secret paired with the key above.
BITREFILL_API_SECRET=

# Bitrefill API base URL.
BITREFILL_API_BASE=https://api.bitrefill.com/v2

# Live Bitrefill payment method. Use balance with test credits, or a crypto
# method such as usdc_base for payment-link testing.
BITREFILL_PAYMENT_METHOD=balance

# Required when BITREFILL_PAYMENT_METHOD=balance.
BITREFILL_BALANCE_CURRENCY=EUR

# Sent on Bitrefill HTTP requests; useful because Cloudflare can reject clients
# without a real User-Agent.
BITREFILL_USER_AGENT=Giftr/1.0 (+https://github.com/Heinrich-Kemler/Giftr)

# Set to true to bypass real Bitrefill calls and run in mock mode (safe testing).
BITREFILL_MOCK=false

# Base URL of this app, used to build absolute links (e.g. raffle share links).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Set to true to include per-service health details. Defaults to true outside
# production and false in production.
HEALTH_DETAILS=false
